# .npmrc — frontend-monorepo
# pnpm configuration

# Hoist all packages to node_modules/.pnpm for compatibility with tools
# that expect a flat node_modules (e.g. some ESLint plugins, Turborepo).
shamefully-hoist=true

# Strict peer dependencies — fail if peer deps are missing.
strict-peer-dependencies=false

# Auto-install peer dependencies.
auto-install-peers=true
