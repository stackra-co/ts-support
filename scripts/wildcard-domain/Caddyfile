# =============================================================================
# Caddyfile — Local Development Reverse Proxy
# =============================================================================
#
# Routes wildcard subdomains to the Vite dev server or production app.
#
# Local development (pnpm dev):
#   http://pixielity.test       → localhost:5173
#   http://acme.pixielity.test  → localhost:5173
#
# Docker (docker-compose up):
#   http://pixielity.test       → app:8080
#   http://acme.pixielity.test  → app:8080
#
# The subdomain is passed to the app via the Host header.
# The multitenancy package's SubdomainResolver reads it.
#
# =============================================================================

{
    # Disable automatic HTTPS — we're on .test local domains
    auto_https off
}

# ── Local development — proxy to Vite dev server ────────────────────────────
http://pixielity.test, http://*.pixielity.test {
    reverse_proxy localhost:5173
}
