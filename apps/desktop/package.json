{
  "name": "@pixielity/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Pixielity Desktop — Electron shell wrapping the Vite app",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -n vite,electron \"pnpm --filter @pixielity/vite dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "pnpm --filter @pixielity/vite build && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "package": "pnpm build && electron-builder",
    "package:mac": "pnpm build && electron-builder --mac",
    "package:win": "pnpm build && electron-builder --win",
    "package:linux": "pnpm build && electron-builder --linux"
  },
  "dependencies": {
    "@abdokouta/ts-desktop": "workspace:*"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.0",
    "typescript": "^5.6.0"
  }
}
